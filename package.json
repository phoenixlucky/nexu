{
  "name": "nexu",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--conditions=development pnpm --parallel --filter @nexu/api --filter @nexu/web --filter @nexu/landing dev",
    "dev:landing": "pnpm --filter @nexu/landing dev",
    "dev:gateway": "OPENCLAW_STATE_DIR=.openclaw openclaw gateway run --allow-unconfigured --bind loopback --port 18789 --force --verbose",
    "dev:sidecar": "pnpm --filter @nexu/gateway dev",
    "build": "pnpm -r build",
    "check:esm-imports": "node scripts/check-esm-specifiers.mjs",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check . && pnpm -r typecheck",
    "format": "biome check --write .",
    "test": "pnpm -r test",
    "generate-types": "pnpm --filter @nexu/api generate-openapi && pnpm --filter @nexu/web generate-sdk",
    "seed": "pnpm --filter @nexu/api db:seed",
    "db:push": "pnpm --filter @nexu/api db:push"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.3.1"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.26.0",
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
  }
}
