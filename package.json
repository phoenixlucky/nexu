{
  "name": "nexu",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--conditions=development concurrently --kill-others --names controller,web --prefix-colors blue,green \"pnpm --filter @nexu/controller dev\" \"pnpm --filter @nexu/web dev\"",
    "dev:controller": "pnpm --filter @nexu/controller dev",
    "dev:desktop": "pnpm --filter @nexu/desktop dev",
    "build": "pnpm -r build",
    "check:esm-imports": "node scripts/check-esm-specifiers.mjs",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check . && pnpm -r typecheck",
    "lint:fix": "biome check --write --unsafe . && pnpm -r typecheck",
    "format": "biome check --write .",
    "test": "vitest run",
    "generate-types": "pnpm --filter @nexu/controller generate-openapi && pnpm --filter @nexu/web generate-sdk",
    "openclaw-runtime:install": "npm --prefix ./openclaw-runtime run install:cached",
    "openclaw-runtime:refresh-lock": "npm --prefix ./openclaw-runtime run refresh-lock",
    "openclaw-runtime:reinstall": "npm --prefix ./openclaw-runtime run clean && npm --prefix ./openclaw-runtime run install:pruned",
    "postinstall": "npm --prefix ./openclaw-runtime run install:pruned && npm --prefix ./apps/controller/static/runtime-plugins/openclaw-weixin install --production --ignore-scripts",
    "prepare": "cp scripts/pre-commit .git/hooks/pre-commit 2>/dev/null; chmod +x .git/hooks/pre-commit 2>/dev/null; true",
    "start": "./scripts/dev-launchd.sh start",
    "stop": "./scripts/dev-launchd.sh stop",
    "restart": "./scripts/dev-launchd.sh restart",
    "status": "./scripts/dev-launchd.sh status",
    "logs": "./scripts/dev-launchd.sh logs",
    "reset-state": "./apps/desktop/dev.sh reset-state",
    "check:dev": "./scripts/desktop-check-dev.sh",
    "check:dist": "./scripts/desktop-check-dist.sh",
    "probe:slack": "node scripts/probe/slack-reply-probe.mjs",
    "dist:mac": "pnpm --filter @nexu/desktop dist:mac",
    "dist:mac:arm64": "pnpm --filter @nexu/desktop dist:mac:arm64",
    "dist:mac:x64": "pnpm --filter @nexu/desktop dist:mac:x64",
    "dist:mac:unsigned": "pnpm --filter @nexu/desktop dist:mac:unsigned",
    "dist:mac:unsigned:arm64": "pnpm --filter @nexu/desktop dist:mac:unsigned:arm64",
    "dist:mac:unsigned:x64": "pnpm --filter @nexu/desktop dist:mac:unsigned:x64"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "vitest": "^3.0.7"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.26.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "better-sqlite3",
      "electron",
      "esbuild"
    ],
    "overrides": {
      "react": "^19.2.4",
      "react-dom": "^19.2.4"
    }
  }
}
