#!/usr/bin/env bash

set -euo pipefail

script_dir="$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)"

openclaw_path="$(node --input-type=module -e 'import { resolveRepoLocalOpenClawLaunchLayout } from "@nexu/openclaw-runtime"; process.stdout.write(resolveRepoLocalOpenClawLaunchLayout(process.argv[1]).openclawPath);' "$script_dir")"

exec node "$openclaw_path" "$@"
